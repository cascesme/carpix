# DATABASE_URL configuration
#
# LOCAL DEV (running outside Docker, Postgres on host):
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/carpix
#
# DOCKER COMPOSE (Postgres reachable via internal compose network):
# DATABASE_URL=postgresql+asyncpg://carpix:carpix@postgres:5432/carpix
#
# Note: docker-compose.yml sets DATABASE_URL directly in the environment block
# and does NOT load this file. This file is for documentation and local dev use only.
